POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=seo_tools
POSTGRES_PORT=15432

ASPNETCORE_ENVIRONMENT=Development
SEO_AUDIT_CORE_API_PORT=5001

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=../secrets/firebase-service-account.json

# JWT RSA configuration
# Provide either PEM text or Base64-encoded PEM for private/public keys.
Jwt__PrivateKeyPem=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
Jwt__PublicKeyPem=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Or use Base64-encoded values instead:
# Jwt__PrivateKeyBase64=...
# Jwt__PublicKeyBase64=...
Jwt__Issuer=your-issuer
Jwt__Audience=your-audience
Jwt__Expireminutes=60
Jwt__RefreshTokenExpireDays=30

# Frontend Configuration
FRONTEND_PORT=3000
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

