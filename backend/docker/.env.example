POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=seo_tools
POSTGRES_PORT=15432

ASPNETCORE_ENVIRONMENT=Development
SEO_AUDIT_CORE_API_PORT=5001

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=../secrets/firebase-service-account.json

# JWT RSA configuration
# Provide either PEM text or Base64-encoded DER/PEM for private/public keys.
JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Or use Base64-encoded values instead:
# JWT_PRIVATE_KEY_BASE64=...
# JWT_PUBLIC_KEY_BASE64=...
JWT_ISSUER=seo_tools
JWT_AUDIENCE=seo_tools
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend Configuration
FRONTEND_PORT=3000
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_API_BASE_URL=http://localhost:5001
